{
  "name": "azure-devops-dependent-picklist",
  "version": "0.1.0",
  "private": true,
  "description": "Configurable dependent picklists for Azure Boards work items.",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && tfx extension create --manifest-globs azure-devops-extension.json"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.259.0",
    "azure-devops-extension-sdk": "^4.0.2",
    "azure-devops-ui": "^2.254.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^2.1.8"
  }
}
