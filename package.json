{
  "name": "azure-devops-dependent-picklist",
  "version": "0.1.0",
  "private": true,
  "description": "Configurable dependent picklists for Azure Boards work items.",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && tfx extension create --manifest-globs azure-devops-extension.json"
  },
  "dependencies": {
    "azure-devops-extension-api": "^5.274.0",
    "azure-devops-extension-sdk": "^5.0.0",
    "azure-devops-ui": "^2.276.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
